{label:'Python reconstruct',body:`from scapy.all import rdpcap, TCP, Raw
from collections import defaultdict

pkts = rdpcap('capture.pcap')
streams = defaultdict(bytes)
for pkt in pkts:
    if pkt.haslayer(TCP) and pkt.haslayer(Raw):
        key = (pkt[TCP].sport, pkt[TCP].dport)
        streams[key] += pkt[Raw].load
for k, v in streams.items():
    if b'flag' in v.lower():
        print(k, v[:200])`}],
},
