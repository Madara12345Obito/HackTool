{label:'Quick solve template',body:`from pwn import *
import requests, re

FLAG = re.compile(r'(flag|ctf|picoCTF)\{[^}]+\}', re.I)

def solve_pwn():
    p = remote('chall.ctf.com', 9001)
    p.recvuntil(b'> ')
    p.sendline(b'A'*64)
    out = p.recvall().decode('utf-8', errors='ignore')
    print(FLAG.findall(out))
    p.interactive()

def solve_web():
    s = requests.Session()
    r = s.get('http://chall.ctf.com/')
    print(FLAG.findall(r.text))

if __name__ == '__main__':
    solve_pwn()`}],
},
