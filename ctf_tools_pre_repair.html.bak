{cat:'network',name:'DNS analysis',tags:['cli','python'],
desc:'DNS recon — zone transfer, TXT records, subdomain enum',
about:'DNS records เก็บข้อมูลสำคัญ เช่น TXT records มักซ่อน flag, zone transfer เปิดเผย subdomains ทั้งหมด',
usage:[
{label:'dig',body:`dig target.com ANY            # all records
dig target.com TXT            # often contains flags!
dig target.com MX             # mail servers
dig @ns1.target.com target.com AXFR  # zone transfer
dig +short target.com         # short IP only
dig -x 8.8.8.8               # reverse DNS lookup`},
{label:'Python dnspython',body:`import dns.resolver  # pip install dnspython
r = dns.resolver.Resolver()
for rtype in ['A','MX','TXT','NS','CNAME','AAAA']:
    try:
        for ans in r.resolve('target.com', rtype):
            print(rtype, ans)
    except: pass`}],
},

