desc:'Trace library calls (ltrace) และ syscalls (strace) ของ binary',
about:'ltrace/strace ช่วยเข้าใจ binary โดยไม่ต้อง decompile ltrace ดู library function calls เช่น strcmp, printf strace ดู OS syscalls เช่น open, read, write',
usage:[
{label:'ltrace — หา hardcoded values',body:`ltrace ./binary
ltrace ./binary 2>&1 | grep -i "strcmp\|password\|flag"
# เห็น: strcmp("user_input", "s3cr3t") → เจอ flag ได้เลย!
ltrace -f ./binary  # follow forks`},
{label:'strace — syscall trace',body:`strace ./binary
strace -e trace=read,write ./binary   # filter syscalls
strace -e openat ./binary             # ดูว่าเปิดไฟล์อะไร
strace -s 1000 ./binary               # print strings ยาวขึ้น`}],
tips:['ltrace + strcmp เจอ hardcoded password บ่อยมาก','strace ดู file ที่เปิด หรือ network connection'],
},
{cat:'reversing',name:'z3 SMT solver',url:'https://github.com/Z3Prover/z3',tags:['python'],
desc:'Constraint solver — แก้ math constraint จาก crackme อัตโนมัติ',
about:'Z3 เป็น SMT solver จาก Microsoft Research ใช้ใน CTF reversing เพื่อแก้ constraint equations ที่ได้จาก decompiled code เช่น flag validation ที่เป็น linear equations',
install:'pip3 install z3-solver',
usage:[
{label:'Solve flag constraints',body:`from z3 import *

# สมมติ decompile แล้วเห็น:
# flag[0] + flag[1] == 0xca
# flag[1] * 2 == flag[2]
# flag[0] ^ flag[3] == 0x40

flag = [BitVec(f'f{i}', 8) for i in range(4)]
s = Solver()

# printable characters
for f in flag:
    s.add(f >= 0x20, f <= 0x7e)

# constraints from decompiled code
s.add(flag[0] + flag[1] == 0xca)
s.add(flag[1] * 2 == flag[2])
s.add(flag[0] ^ flag[3] == 0x40)

if s.check() == sat:
    m = s.model()
    result = bytes([m[f].as_long() for f in flag])
    print('[FLAG]', result.decode())`}],
tips:['ดี กับ crackme ที่เป็น linear algebra / bitwise constraints','ใช้ร่วมกับ Ghidra: copy constraint จาก pseudocode → z3'],
},


