},
{cat:'reversing',name:'angr symbolic execution',url:'https://angr.io/',tags:['python'],
desc:'Symbolic execution — auto-solve crackme โดยไม่ต้อง reverse ด้วยมือ',
about:'angr แทน input ด้วย symbolic value แล้ว explore execution paths ทั้งหมด หา input ที่ทำให้โปรแกรมถึง success state (Correct/flag) ใช้กับ crackme ที่มี complex validation',
install:'pip3 install angr',
usage:[
{label:'Auto-solve crackme',body:`import angr, claripy

proj = angr.Project('./crackme', auto_load_libs=False)
flag = claripy.BVS('flag', 8*32)   # 32-byte symbolic input

state = proj.factory.entry_state(
    stdin=angr.SimFile(name='stdin', content=flag)
)
sm = proj.factory.simulation_manager(state)
sm.explore(
    find=lambda s: b'Correct' in s.posix.dumps(1),
    avoid=lambda s: b'Wrong' in s.posix.dumps(1)
)
if sm.found:
    sol = sm.found[0]
    print('[FLAG]', sol.posix.dumps(0))`},
{label:'Find by address',body:`sm.explore(find=0x401234, avoid=0x401567)
if sm.found:
    print(sm.found[0].posix.dumps(0))`}],
tips:['ช้ากว่า manual แต่ดีมากกับ complex math checks','ใส่ avoid ให้มากเพื่อ prune paths','ถ้า timeout → ลด input size หรือ hook ส่วนที่ซับซ้อน'],
},
