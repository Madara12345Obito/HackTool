{cat:'misc',name:'Audio Steganography',tags:['python','cli'],
desc:'ซ่อน/ค้นข้อมูลในไฟล์เสียง — spectrogram, LSB, DTMF',
about:'Audio stego เจอบ่อยใน CTF misc/forensics มีหลายวิธี: hidden image ใน spectrogram, LSB ของ audio samples, Morse code, DTMF tones',
usage:[{label:'Spectrogram analysis',body:`# ดู hidden image ใน frequency domain:
sox audio.wav -n spectrogram -o spec.png
# เปิด spec.png → ดูว่ามี text/image ซ่อนอยู่ไหม

# ด้วย Python:
import numpy as np, matplotlib.pyplot as plt
import scipy.io.wavfile as wav

rate, data = wav.read('audio.wav')
plt.specgram(data[:,0] if data.ndim>1 else data,
             Fs=rate, NFFT=2048, noverlap=512)
plt.savefig('spec.png', dpi=200)

# หรือใช้ Audacity: View → Spectrogram`},
{label:'LSB audio extraction',body:`import wave, struct

def extract_lsb(wav_path, num_bits=8*100):
    w = wave.open(wav_path)
    n = w.getnframes()
    frames = w.readframes(n)
    samples = struct.unpack('<' + 'h'*n, frames)
    bits = ''.join(str(s & 1) for s in samples[:num_bits])
    # แปลง bits → bytes
    msg = int(bits, 2).to_bytes(len(bits)//8, 'big')
    return msg

msg = extract_lsb('audio.wav')
print(msg)`}],
},

