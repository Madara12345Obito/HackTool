{cat:'crypto',name:'openssl',url:'https://www.openssl.org/',tags:['cli'],
desc:'Crypto Swiss Army knife — encrypt, decrypt, generate keys, analyze certs',
about:'openssl CLI เป็น tool สำหรับจัดการ keys, certificates, และ crypto operations ทุกอย่าง ใช้ใน CTF สำหรับ inspect public keys, extract n/e, decrypt RSA, convert formats',
usage:[
{label:'RSA key inspection',body:`# ดู public key components (n, e)
openssl rsa -in pub.pem -pubin -text -noout
openssl asn1parse -in pub.pem  # raw ASN.1

# สร้าง private key จาก p, q, e ด้วย Python:
from Crypto.PublicKey import RSA
import gmpy2
p=...; q=...; e=65537
n=p*q; phi=(p-1)*(q-1)
d=int(gmpy2.invert(e,phi))
key=RSA.construct((n,e,d,p,q))
print(key.export_key().decode())`},
{label:'Encrypt/Decrypt',body:`# Decrypt ด้วย private key
openssl rsautl -decrypt -inkey priv.pem -in cipher.bin -out plain.txt
# Encrypt
openssl rsautl -encrypt -pubin -inkey pub.pem -in plain.txt -out cipher.bin
# AES decrypt
openssl enc -d -aes-256-cbc -in encrypted.bin -out plain.txt -k "password"
# Base64 decode
openssl base64 -d -in encoded.txt -out decoded.bin`},
{label:'Certificate analysis',body:`openssl x509 -in cert.pem -text -noout    # ดู cert
openssl x509 -in cert.pem -pubkey -noout  # extract public key
openssl s_client -connect target.com:443  # inspect TLS
# PKCS12
openssl pkcs12 -in cert.p12 -nokeys -out cert.pem
openssl pkcs12 -in cert.p12 -nocerts -out key.pem`}],
},
{cat:'crypto',name:'pycryptodome',url:'https://pycryptodome.readthedocs.io/',tags:['python'],
desc:'Python crypto library — AES, RSA, DES, SHA, HMAC ฯลฯ',
about:'pycryptodome (fork ของ pycrypto) เป็น crypto library Python ที่ใช้บ่อยมากใน CTF สำหรับ implement และ attack crypto algorithms',
install:'pip3 install pycryptodome',
usage:[
{label:'AES operations',body:`from Crypto.Cipher import AES
from Crypto.Util.Padding import pad, unpad
import os

key = os.urandom(16)  # 128-bit key
iv  = os.urandom(16)

# Encrypt (CBC mode)
cipher = AES.new(key, AES.MODE_CBC, iv)
ct = cipher.encrypt(pad(b'plaintext...', 16))

# Decrypt
cipher2 = AES.new(key, AES.MODE_CBC, iv)
pt = unpad(cipher2.decrypt(ct), 16)

# ECB mode (no iv, weak!)
cipher3 = AES.new(key, AES.MODE_ECB)
# detect ECB: same 16-byte block → same ciphertext`},
{label:'RSA with pycryptodome',body:`from Crypto.PublicKey import RSA
from Crypto.Cipher import PKCS1_OAEP

# Load key
key = RSA.import_key(open('pub.pem').read())
n, e = key.n, key.e

# Encrypt
cipher = PKCS1_OAEP.new(key)
ct = cipher.encrypt(b'secret')

# Decrypt (ต้องมี private key)
priv = RSA.import_key(open('priv.pem').read())
cipher2 = PKCS1_OAEP.new(priv)
pt = cipher2.decrypt(ct)`},
{label:'Hash + HMAC',body:`from Crypto.Hash import SHA256, MD5, HMAC
from Crypto.Hash import SHA256

h = SHA256.new(b'data')
print(h.hexdigest())

# HMAC
mac = HMAC.new(b'secret_key', b'message', SHA256)
print(mac.hexdigest())

# Length extension attack:
# pip install hashpumpy
import hashpumpy
new_sig, new_msg = hashpumpy.hashpump(
    known_sig, known_msg, append_data, key_len
)`}],
},
{cat:'crypto',name:'RSA CTF Patterns',tags:['python'],
desc:'รวม RSA attack patterns ที่เจอบ่อยใน CTF พร้อม code',
about:'สรุป patterns ที่เจอบ่อยที่สุดใน RSA CTF challenges พร้อม Python code สำเร็จรูป',
usage:[
{label:'Common Modulus Attack',body:`# ถ้า n เหมือนกัน สอง ciphertext ใช้ e ต่างกัน
# c1 = m^e1 mod n, c2 = m^e2 mod n
# ถ้า gcd(e1,e2) = 1 → recover m

from math import gcd
import gmpy2

def extended_gcd(a, b):
    if a == 0: return b, 0, 1
    g, x, y = extended_gcd(b%a, a)
    return g, y-(b//a)*x, x

g = gcd(e1, e2)
if g != 1: raise Exception("gcd(e1,e2) != 1")

_, a, b = extended_gcd(e1, e2)
if a < 0:
    a = -a; c1 = gmpy2.invert(c1, n)
if b < 0:
    b = -b; c2 = gmpy2.invert(c2, n)
m = (pow(c1,a,n) * pow(c2,b,n)) % n
print(m.to_bytes((m.bit_length()+7)//8,'big'))`},
{label:'Hastad Broadcast Attack',body:`# e=3, ส่ง m ไปยัง 3 receivers (n1,n2,n3 ต่างกัน)
# c1=m^3 mod n1, c2=m^3 mod n2, c3=m^3 mod n3
from sympy.ntheory.modular import crt
import gmpy2

ns = [n1, n2, n3]
cs = [c1, c2, c3]
# CRT: หา x s.t. x ≡ ci (mod ni)
_, m3 = crt(ns, cs)
m, ok = gmpy2.iroot(m3, 3)
if ok:
    print(int(m).to_bytes((int(m).bit_length()+7)//8,'big'))`},
{label:'Padding Oracle / LSB Oracle',body:`# LSB Oracle: server บอกว่า m เป็น odd/even
# เป็น binary search บน plaintext space
lo, hi = 0, n
for _ in range(n.bit_length()):
    c = (c * pow(2, e, n)) % n  # shift left
    parity = oracle(c)           # 0=even, 1=odd
    mid = (lo + hi) // 2
    if parity == 0:
        hi = mid
    else:
        lo = mid
m = lo
print(m.to_bytes((m.bit_length()+7)//8,'big'))`},
{label:'Coppersmith / small roots',body:`# Sage: หา small root ของ polynomial mod n
# ใช้เมื่อ m บางส่วนรู้แล้ว (เช่น prefix/suffix)
# ใน SageMath:
N = Integer(n)
P.<x> = PolynomialRing(Zmod(N), implementation='NTL')
pol = (known_prefix + x)^e - c
roots = pol.small_roots(X=2^64, beta=0.5)
print(roots)`}],
},

/* ── STEGO EXTRAS ── */
{cat:'stego',name:'PIL/numpy LSB Analysis',url:'https://pillow.readthedocs.io/',tags:['python'],
desc:'วิเคราะห์ LSB ของรูปภาพด้วย Python โดยตรง',
about:'เมื่อ tool อื่น detect ว่ามี LSB stego แต่ไม่ extract ได้ ต้องเขียน Python เองเพื่อควบคุม bit order, channel order, และ termination condition',
install:'pip3 install Pillow numpy',
usage:[
{label:'Extract LSB จาก RGB',body:`from PIL import Image
import numpy as np

img = Image.open('challenge.png').convert('RGB')
arr = np.array(img)

# Extract LSB ทุก pixel ทุก channel (R,G,B), row by row
bits = ''
for row in arr:
    for pixel in row:
        for channel in pixel:
            bits += str(channel & 1)

# แปลง bits → bytes
data = int(bits, 2).to_bytes(len(bits)//8, 'big')

# หา null terminator หรือ flag pattern
flag_idx = data.find(b'flag{')
if flag_idx >= 0:
    end = data.find(b'}', flag_idx)
    print(data[flag_idx:end+1].decode())`},
{label:'Try all channel orders',body:`from PIL import Image
import numpy as np
from itertools import permutations

img = Image.open('challenge.png').convert('RGB')
arr = np.array(img)

# ลอง channel orders ต่างๆ: RGB, RBG, GRB, GBR, BRG, BGR
for order in permutations([0,1,2]):
    bits = ''.join(str(arr[r,c,ch] & 1)
                   for r in range(arr.shape[0])
                   for c in range(arr.shape[1])
                   for ch in order)
    data = int(bits,2).to_bytes(len(bits)//8,'big')
    if b'flag' in data.lower():
        name = ['R','G','B']
        print('Found! order:', [name[i] for i in order])
        print(data[:100])`},
{label:'MSB / Multiple bits',body:`# สกัด 2 LSBs แทน 1
bits = ''.join(format(p & 3,'02b')
               for row in arr for pixel in row for p in pixel)

# MSB แทน LSB
bits = ''.join(str((p >> 7) & 1)
               for row in arr for pixel in row for p in pixel)`}],
tips:['ลอง bit order: LSB first vs MSB first','ลอง pixel order: row-major vs column-major','ถ้ามี alpha channel → ลอง RGBA ด้วย'],
},
{cat:'stego',name:'Audio Analysis (sox/scipy)',url:'http://sox.sourceforge.net/',tags:['cli','python'],
desc:'วิเคราะห์ audio file อย่างละเอียด — spectrogram, frequency analysis',
about:'การซ่อนข้อมูลใน audio มีหลายวิธี ที่เจอบ่อยสุดคือ spectrogram (ดูภาพใน frequency domain), LSB encoding, phase encoding, และ Morse/DTMF',
install:'sudo apt install sox\npip3 install scipy matplotlib',
usage:[
{label:'Spectrogram ละเอียด',body:`import numpy as np
import matplotlib.pyplot as plt
from scipy.io import wavfile
from scipy import signal

rate, data = wavfile.read('audio.wav')
if data.ndim > 1:
    data = data[:,0]  # mono

# STFT spectrogram
f, t, Sxx = signal.stft(data, fs=rate, nperseg=2048, noverlap=1800)
plt.figure(figsize=(20, 6))
plt.pcolormesh(t, f, 20*np.log10(np.abs(Sxx)+1e-10), cmap='inferno')
plt.ylim(0, rate//2)
plt.xlabel('Time (s)'); plt.ylabel('Frequency (Hz)')
plt.title('Spectrogram')
plt.colorbar(label='dB')
plt.savefig('spectrogram_hires.png', dpi=300, bbox_inches='tight')
print('Saved spectrogram_hires.png')`},
{label:'Extract LSB audio',body:`import wave, struct, numpy as np

def extract_lsb_audio(path, nbits=1):
    w = wave.open(path)
    nframes = w.getnframes()
    raw = w.readframes(nframes)
    w.close()
    n = nframes * w.getnchannels() if hasattr(w,'getnchannels') else nframes
    fmt = '<' + 'h' * (len(raw)//2)
    samples = struct.unpack(fmt, raw)
    bits = ''
    for s in samples:
        for b in range(nbits):
            bits += str((s >> b) & 1)
    data = bytearray()
    for i in range(0, len(bits)-7, 8):
        data.append(int(bits[i:i+8], 2))
    return bytes(data)

raw = extract_lsb_audio('audio.wav')
print(raw[:200])`},
{label:'sox commands',body:`# สร้าง spectrogram
sox audio.wav -n spectrogram -o spec.png
sox audio.wav -n spectrogram -x 1200 -y 300 -o spec_wide.png

# แปลง format
sox input.mp3 output.wav
sox input.wav -r 44100 -b 16 output.wav  # re-sample

# Stats
sox audio.wav -n stat  # ดู statistics
sox audio.wav -n noiseprof noise.prof    # noise profile`}],
},


