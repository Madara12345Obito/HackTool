/* ═══════════ CRYPTOGRAPHY ═══════════ */
{cat:'crypto',name:'dCode',url:'https://www.dcode.fr',tags:['online'],
desc:'สวรรค์ crypto — ตัวถอดรหัส 200+ cipher + Cipher Identifier อัตโนมัติ',
about:'dCode คือ reference สำหรับ classical ciphers ที่ครบที่สุด มีทั้ง Caesar, Vigenere, Playfair, Rail Fence, Bacon, Polybius, Beaufort, Affine, Hill cipher ฯลฯ จุดเด่นคือ Cipher Identifier ที่วิเคราะห์ ciphertext แล้วเดาประเภทให้',
usage:[{label:'Cipher Identifier',body:`1. เปิด https://www.dcode.fr/cipher-identifier
2. วาง ciphertext ลงในช่อง
3. กด Analyze → มันจะแสดงรายการ cipher ที่เป็นไปได้
4. ลองถอดรหัสด้วย cipher แต่ละตัว`},
{label:'Quick cheat — ดูจาก pattern',body:`Only A-Z uppercase, no space  → Caesar / Vigenere
Numbers 1-26 only             → A1Z26 (A=1,B=2..)
Dots and dashes               → Morse code
+ . symbols (Pigpen-style)    → Tap code / Braille
Groups of 5 letters           → Playfair หรือ Polybius
Symbol substitution           → dCode "Symbolic Ciphers"
A/B sequences (binary-looking)→ Bacon's cipher
Numbers pairs 1-5             → Polybius square`}],
tips:['ไม่รู้ว่าเป็น cipher อะไร → ลอง Cipher Identifier ก่อนเสมอ','dCode มี "Beaufort" และ "Vigenere variant" หลายตัว','ลอง ROT bruteforce ก่อนถ้าเห็น text อังกฤษแปลกๆ'],
},
{cat:'crypto',name:'RsaCtfTool',url:'https://github.com/Ganapati/RsaCtfTool',tags:['python','cli'],
desc:'โจมตี RSA อัตโนมัติ — wiener, small_e, hastad, factordb, common modulus ฯลฯ',
about:'เครื่องมือที่รวม RSA attack หลายสิบแบบไว้ในที่เดียว รัน attack ทั้งหมดพร้อมกันได้ รองรับ key ใน format PEM, DER, raw n/e ติดตั้ง dependencies หลายตัว (SageMath, yafu ฯลฯ) แต่พื้นฐานทำงานได้โดยไม่ต้องครบ',
install:`git clone https://github.com/Ganapati/RsaCtfTool
cd RsaCtfTool
pip3 install -r requirements.txt
# (optional) ติดตั้ง SageMath สำหรับ attack เพิ่มเติม`,
usage:[{label:'จาก public key + ciphertext',body:`python3 RsaCtfTool.py --publickey pub.pem --uncipherfile cipher.enc
python3 RsaCtfTool.py --publickey pub.pem --uncipher <hex>`},
{label:'ระบุ n, e โดยตรง',body:`python3 RsaCtfTool.py --n 1234567890... --e 65537 --uncipher 9876...
python3 RsaCtfTool.py --publickey pub.pem --attack all`},
{label:'Attack checklist ด้วยมือ',body:`# 1. small e + small m → cube root
import gmpy2
m, ok = gmpy2.iroot(c, e)
if ok: print(bytes.fromhex(hex(m)[2:]))

# 2. Wiener (small d) → ใช้ RsaCtfTool --attack wiener
# 3. Fermat (p ≈ q)
import math
a = math.isqrt(n) + 1
while True:
    b2 = a*a - n
    b, ok = gmpy2.iroot(b2, 2)
    if ok: break
    a += 1
p, q = a-b, a+b

# 4. FactorDB
from factordb.factordb import FactorDB
f = FactorDB(n); f.connect()
p, q = f.get_factor_list()`}],
tips:['--attack all ลองทุก method ช้าแต่สะดวก','ถ้า factor ได้ → d = modinv(e, (p-1)*(q-1))'],
},
{cat:'crypto',name:'FactorDB',url:'http://factordb.com/',tags:['online','python'],
desc:'ฐานข้อมูล integer factorization — ถ้า n เคยถูก factor มาก่อนพบที่นี่ทันที',
about:'ฐานข้อมูลรวม factorization ของตัวเลขที่เคยคำนวณมาแล้วทั่วโลก ถ้า n ของ RSA อยู่ในฐานข้อมูลจะได้ p, q ทันที โดยไม่ต้องคำนวณ',
usage:[{label:'Python API',body:`from factordb.factordb import FactorDB
f = FactorDB(n)
f.connect()
factors = f.get_factor_list()
if len(factors) == 2:
    p, q = factors
    phi = (p-1)*(q-1)
    import gmpy2
    d = int(gmpy2.invert(e, phi))
    m = pow(c, d, n)
    print(bytes.fromhex(hex(m)[2:]))`},
{label:'คำนวณ d, decrypt เมื่อได้ p, q',body:`def modinv(a, m):
    g, x, _ = extended_gcd(a, m)
    return x % m

def extended_gcd(a, b):
    if a == 0: return b, 0, 1
    g, x, y = extended_gcd(b%a, a)
    return g, y - (b//a)*x, x

phi = (p-1)*(q-1)
d = modinv(e, phi)
m = pow(c, d, n)
flag = m.to_bytes((m.bit_length()+7)//8,'big')
print(flag.decode())`}],
},
{cat:'crypto',name:'CrackStation',url:'https://crackstation.net/',tags:['online'],
desc:'ถอด hash ออนไลน์ฟรี — MD5, SHA-1, SHA-256, SHA-512 + rainbow table ใหญ่',
about:'มี rainbow table ขนาดใหญ่มาก (เกือบ 20 GB) รองรับ MD5, SHA-1, SHA-224, SHA-256, SHA-384, SHA-512, LM, NTLM, mysql ฯลฯ เหมาะสำหรับ hash ที่มาจาก common passwords',
