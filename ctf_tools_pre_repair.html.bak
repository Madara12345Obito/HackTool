usage:[
{label:'Classic encodings',body:`import base64, binascii
from urllib.parse import unquote
import html as html_lib

base64.b64decode("SGVsbG8=")           # Base64
base64.b32decode("JBSWY3DP")           # Base32
base64.b85decode("Xk~0{Zv")            # Base85
bytes.fromhex("48656c6c6f")             # Hex
binascii.a2b_uu("!0V5L90\`\`\`\`")       # UUencode
unquote("%66%6c%61%67%7b%68%69%7d")    # URL encode
html_lib.unescape("flag&#123;hi&#125;") # HTML entities
"\u0066\u006c\u0061\u0067".encode().decode('unicode_escape')`},
{label:'Cipher shortcuts',body:`# A1Z26: numbers → letters
msg = [6, 12, 1, 7]
print(''.join(chr(n+64) for n in msg))  # FLAG

# Atbash: A↔Z
ct = "SVOOL"
print(''.join(chr(90-(ord(c)-65)) if c.isupper() else c for c in ct))

# ROT bruteforce
for i in range(26):
    print(i,''.join(
        chr((ord(c)-65+i)%26+65) if c.isupper() else
        chr((ord(c)-97+i)%26+97) if c.islower() else c
        for c in "URYYB"
    ))

# Bacon cipher (AAAAA=A, AAAAB=B...)
BACON = {'AAAAA':'A','AAAAB':'B','AAABA':'C','AAABB':'D',
         'AABAA':'E','AABAB':'F','AABBA':'G','AABBB':'H',
         'ABAAA':'I','ABAAB':'J','ABABA':'K','ABABB':'L'}`}],
