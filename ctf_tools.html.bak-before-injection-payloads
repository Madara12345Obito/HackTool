<div id="wrap">

<nav id="sidebar">
  <div class="sb-logo">
    <h1>⚑ CTF Tools</h1>
    <p>Self-Contained Reference</p>
  </div>
  <div class="sb-search"><input id="sb-search" placeholder="🔍  ค้นหา..." autocomplete="off"></div>
  <div class="sb-nav" id="sb-nav"></div>
