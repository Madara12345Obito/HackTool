<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚑ CTF Tools — Self-Contained Reference</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
:root{
  --bg:#070710;--bg2:#0e0e1a;--bg3:#14142a;--bg4:#1a1a35;
  --border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.12);
  --text:#e2e4f0;--muted:#6b7099;--muted2:#4a4f70;
  --blue:#5b8dee;--purple:#9b6dff;--cyan:#3ecfcf;--green:#3ecf74;
  --yellow:#f5c842;--orange:#ff8c42;--red:#ff5c7a;--pink:#e55fcc;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif;font-size:13.5px;line-height:1.6;min-height:100vh;overflow-x:hidden}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:99px}

/* layout */
#wrap{display:flex;height:100vh;overflow:hidden}

/* sidebar */
#sidebar{width:220px;min-width:220px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto}
.sb-logo{padding:18px 16px 12px;border-bottom:1px solid var(--border)}
.sb-logo h1{font-size:14px;font-weight:700;background:linear-gradient(135deg,var(--blue),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.sb-logo p{font-size:10px;color:var(--muted);margin-top:1px}
.sb-search{padding:10px 10px 6px}
.sb-search input{width:100%;padding:7px 11px;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-size:12px;outline:none;font-family:inherit}
.sb-search input:focus{border-color:var(--blue)}
.sb-search input::placeholder{color:var(--muted2)}
.sb-nav{padding:4px 8px;flex:1}
.sb-label{padding:8px 8px 3px;font-size:9.5px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.8px}
.sb-item{display:flex;align-items:center;gap:8px;padding:6px 9px;border-radius:7px;cursor:pointer;transition:all .12s;font-size:12px;color:var(--muted);border:none;background:none;width:100%;text-align:left;position:relative}
.sb-item:hover{background:var(--bg3);color:var(--text)}
.sb-item.active{background:var(--bg4);color:var(--text)}
.sb-item.active::before{content:'';position:absolute;left:0;top:25%;bottom:25%;width:3px;border-radius:0 3px 3px 0;background:var(--c,var(--blue))}
.sb-dot{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;background:color-mix(in srgb,var(--c,var(--blue)) 15%,transparent)}
.sb-count{margin-left:auto;font-size:9px;color:var(--muted2);background:var(--bg3);padding:1px 5px;border-radius:99px}
.sb-footer{padding:10px 14px;border-top:1px solid var(--border);font-size:10px;color:var(--muted2);line-height:1.7}

/* main */
#main{flex:1;overflow-y:auto;overflow-x:hidden;display:flex;flex-direction:column}
#topbar{padding:16px 28px 12px;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50;background:rgba(7,7,16,.85);backdrop-filter:blur(14px)}
#pt{font-size:19px;font-weight:700;background:linear-gradient(90deg,var(--blue),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
#pt-count{font-size:11px;color:var(--muted);margin-top:1px}
#content{padding:20px 28px 60px;flex:1}

/* section */
.sec{margin-bottom:40px}
.sec-head{display:flex;align-items:center;gap:9px;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.sec-icon{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;background:color-mix(in srgb,var(--c,var(--blue)) 15%,transparent)}
.sec-title{font-size:14px;font-weight:700}
.sec-badge{margin-left:auto;padding:1px 8px;border-radius:99px;font-size:9.5px;font-weight:600;background:color-mix(in srgb,var(--c,var(--blue)) 13%,transparent);color:var(--c,var(--blue))}

/* tool grid */
.tool-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:9px}

/* card */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:11px;overflow:hidden;transition:border-color .2s}
.card:hover{border-color:color-mix(in srgb,var(--c,var(--blue)) 40%,transparent)}
.card-header{padding:12px 14px;cursor:pointer;display:flex;flex-direction:column;gap:6px;user-select:none}
.card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:6px}
.card-name{font-size:13px;font-weight:600;color:var(--c,var(--blue));display:flex;align-items:center;gap:5px}
.card-name .dot{width:5px;height:5px;border-radius:50%;background:var(--c,var(--blue));flex-shrink:0}
.card-expand{font-size:10px;color:var(--muted2);background:var(--bg3);padding:3px 8px;border-radius:5px;flex-shrink:0;transition:all .15s;cursor:pointer;border:1px solid var(--border)}
.card-expand:hover{border-color:var(--border2);color:var(--text)}
.card-desc{font-size:12px;color:var(--text);opacity:.8;line-height:1.5}
.card-tags{display:flex;flex-wrap:wrap;gap:3px}
.tag{font-size:9.5px;font-weight:500;padding:1px 7px;border-radius:99px}
.tag-online{background:rgba(62,207,116,.1);color:#3ecf74}
.tag-cli{background:rgba(255,92,122,.1);color:#ff5c7a}
.tag-python{background:rgba(155,109,255,.1);color:#9b6dff}
.tag-java{background:rgba(245,200,66,.1);color:#f5c842}
.tag-ruby{background:rgba(229,95,204,.1);color:#e55fcc}

/* expandable body */
.card-body{display:none;border-top:1px solid var(--border)}
.card-body.open{display:block}

/* tabs */
.tabs{display:flex;gap:0;border-bottom:1px solid var(--border);padding:0 14px;background:var(--bg3)}
.tab{padding:7px 12px;font-size:11px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.tab:hover{color:var(--text)}
.tab.active{color:var(--c,var(--blue));border-bottom-color:var(--c,var(--blue))}
.tab-content{display:none;padding:12px 14px}
.tab-content.active{display:block}

/* code block */
.codeblock{background:var(--bg);border:1px solid var(--border);border-radius:7px;overflow:hidden;margin:6px 0}
.code-label{font-size:9px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.6px;padding:4px 10px;background:var(--bg3);border-bottom:1px solid var(--border)}
.codeblock pre{font-family:'JetBrains Mono',monospace;font-size:11px;line-height:1.65;color:#b0b8e0;padding:10px 12px;overflow-x:auto;margin:0;white-space:pre}
.codeblock .copy-btn{float:right;margin:-26px 6px 0 0;font-size:9.5px;padding:2px 7px;border-radius:4px;cursor:pointer;background:var(--bg4);border:1px solid var(--border2);color:var(--muted);transition:.12s;position:relative;z-index:1}
.codeblock .copy-btn:hover{color:var(--text)}

/* inline docs */
.doc-section{margin-bottom:14px}
.doc-section h4{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;display:flex;align-items:center;gap:5px}
.doc-section h4::after{content:'';flex:1;height:1px;background:var(--border)}
.doc-p{font-size:12px;color:var(--text);opacity:.85;line-height:1.6;margin-bottom:6px}
.tip-box{background:rgba(91,141,238,.07);border-left:3px solid var(--blue);border-radius:0 6px 6px 0;padding:7px 10px;font-size:11.5px;color:#8ba8e8;margin:6px 0}
.warn-box{background:rgba(255,140,66,.07);border-left:3px solid var(--orange);border-radius:0 6px 6px 0;padding:7px 10px;font-size:11.5px;color:#e8a878;margin:6px 0}
.checklist{list-style:none;padding:0}
.checklist li{font-size:11.5px;padding:3px 0;color:var(--text);opacity:.85;display:flex;align-items:flex-start;gap:6px}
.checklist li::before{content:'›';color:var(--c,var(--blue));font-weight:700;flex-shrink:0;font-size:13px;line-height:1.3}
.install-cmd{font-family:'JetBrains Mono',monospace;font-size:11px;background:var(--bg3);border:1px solid var(--border);border-radius:5px;padding:3px 8px;color:var(--cyan)}

/* search results */
#search-results{display:none}
.sr-cat-badge{display:inline-block;font-size:9px;padding:1px 7px;border-radius:99px;margin-bottom:5px;background:var(--bg4);color:var(--muted)}
mark{background:rgba(245,200,66,.22);color:#f0d060;border-radius:2px;padding:0 1px}

/* empty */
#empty{display:none;padding:60px;text-align:center;color:var(--muted)}
#empty .ei{font-size:36px;margin-bottom:10px}

/* back to top */
#btt{position:fixed;bottom:20px;right:20px;width:36px;height:36px;border-radius:50%;background:var(--blue);color:#000;border:none;font-size:16px;cursor:pointer;opacity:0;transform:translateY(6px);transition:all .22s;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 12px rgba(91,141,238,.4);z-index:99}
#btt.show{opacity:1;transform:translateY(0)}

@media(max-width:700px){#sidebar{display:none}#content{padding:14px}.tool-grid{grid-template-columns:1fr}}
</style>
</head>
