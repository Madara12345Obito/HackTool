//          tips:[], checklist:[], notes}
// ════════════════════════════════════════════════════════════
const TOOLS=[

/* ═══════════ TRAINING ═══════════ */
{cat:'training',name:'picoCTF',url:'https://picoctf.org/',tags:['online'],
desc:'แพลตฟอร์ม CTF จาก Carnegie Mellon University เหมาะสำหรับมือใหม่ถึงระดับกลาง',
about:'picoCTF เป็น CTF เพื่อการศึกษาที่ใหญ่ที่สุด เปิดตลอดปีในโหมด "picoGym" (ฝึกได้เรื่อยๆ) และมี event แข่งประจำปี ครอบคลุมทุก category: Web, Crypto, Forensics, Reversing, Pwn, General Skills เหมาะเริ่มต้นเพราะมี hint และ writeup เยอะมาก',
tips:['เริ่มที่ General Skills ก่อนเพื่อคุ้นกับ Linux/terminal','แต่ละโจทย์กด "Hints" ได้โดยไม่เสียคะแนน','picoGym เปิดตลอด ไม่ต้องรอ event'],
},
{cat:'training',name:'OverTheWire',url:'https://overthewire.org/wargames/',tags:['online','cli'],
