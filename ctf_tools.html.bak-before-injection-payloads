usage:[{label:'Error Level Analysis (ELA)',body:`# วิธีใช้:
# 1. เปิด https://29a.ch/photo-forensics/#error-level-analysis
# 2. Upload รูป
# 3. ดูบริเวณที่ brightness ต่างออกไป = บริเวณที่ถูก edit
# ELA ทำงานบน JPEG เท่านั้น (compression artifact)

# ด้วย Python:
from PIL import Image
import io, numpy as np

def ela(img_path, quality=90):
    img = Image.open(img_path)
    buf = io.BytesIO()
    img.save(buf, 'JPEG', quality=quality)
    buf.seek(0)
    img2 = Image.open(buf)
    ela_arr = np.abs(np.array(img) - np.array(img2)) * 10
    return Image.fromarray(ela_arr.astype('uint8'))`}],
