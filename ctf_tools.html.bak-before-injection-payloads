{label:'LSB audio extraction',body:`import wave, struct

def extract_lsb(wav_path, num_bits=8*100):
    w = wave.open(wav_path)
    n = w.getnframes()
    frames = w.readframes(n)
    samples = struct.unpack('<' + 'h'*n, frames)
    bits = ''.join(str(s & 1) for s in samples[:num_bits])
    # แปลง bits → bytes
    msg = int(bits, 2).to_bytes(len(bits)//8, 'big')
    return msg

