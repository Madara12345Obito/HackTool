// ════════════════════════════════════════════════════════════
// RENDER ENGINE
// ════════════════════════════════════════════════════════════

function esc(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') }

function tagHtml(t){
  const cls={online:'tag-online',cli:'tag-cli',python:'tag-python',java:'tag-java',ruby:'tag-ruby'};
  return `<span class="tag ${cls[t]||''}">${t}</span>`;
}

function catColor(id){
  return (CATS.find(c=>c.id===id)||{c:'#5b8dee'}).c;
}

function renderCard(tool, q=''){
  const c = catColor(tool.cat);
  const hiE = s => {
    // escape HTML entities first, then apply search highlight
    const escaped = s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    return q
      ? escaped.replace(new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'gi'), m=>`<mark>${m}</mark>`)
      : escaped;
  };
  // alias for non-escaped version (code blocks already use esc())
  const hi = hiE;
  const uid = 'card_' + Math.random().toString(36).slice(2);

  // build tabs
  const tabs=[], contents=[];
  if(tool.about){
    tabs.push({id:'about',label:'ภาพรวม'});
    contents.push(`<div class="tab-content active" id="${uid}_about">
      <div class="doc-section"><div class="doc-p">${hi(tool.about)}</div></div>
      ${tool.tips&&tool.tips.length?`<div class="doc-section">
        <h4>💡 Tips</h4>
        <ul class="checklist">${tool.tips.map(t=>`<li>${hi(t)}</li>`).join('')}</ul>
      </div>`:''}
      ${tool.checklist&&tool.checklist.length?`<div class="doc-section">
        <h4>📋 Wargames / Levels</h4>
        <ul class="checklist">${tool.checklist.map(t=>`<li>${hi(t)}</li>`).join('')}</ul>
      </div>`:''}
    </div>`);
  }
  if(tool.install){
    tabs.push({id:'install',label:'ติดตั้ง'});
    contents.push(`<div class="tab-content" id="${uid}_install">
      <div class="codeblock">
        <div class="code-label">Installation</div>
        <pre>${esc(tool.install)}</pre>
      </div>
    </div>`);
  }
  if(tool.usage&&tool.usage.length){
    tabs.push({id:'usage',label:'วิธีใช้'});
    contents.push(`<div class="tab-content" id="${uid}_usage">
      ${tool.usage.map(u=>`<div class="codeblock">
        <div class="code-label">${u.label}</div>
        <button class="copy-btn" onclick="copyCode(this)">copy</button>
        <pre>${esc(u.body)}</pre>
      </div>`).join('')}
    </div>`);
  }

  const hasExpand = tabs.length > 0;
  const firstTab = hasExpand ? tabs[0].id : '';

  return `<div class="card" style="--c:${c}" id="${uid}">
    <div class="card-header" onclick="toggleCard('${uid}','${firstTab}')">
      <div class="card-top">
        <div class="card-name"><span class="dot"></span>${hi(tool.name)}</div>
        <div style="display:flex;gap:6px;align-items:center">
          ${tool.url?`<a class="card-link" href="${tool.url}" target="_blank" onclick="event.stopPropagation()">↗ เปิด</a>`:''}
          ${hasExpand?`<span class="card-expand" id="${uid}_btn">▾ ดูเพิ่ม</span>`:''}
        </div>
      </div>
      <div class="card-desc">${hi(tool.desc)}</div>
      ${tool.tags&&tool.tags.length?`<div class="card-tags">${tool.tags.map(tagHtml).join('')}</div>`:''}
    </div>
    ${hasExpand?`<div class="card-body" id="${uid}_body">
      <div class="tabs" id="${uid}_tabs">
        ${tabs.map((t,i)=>`<div class="tab${i===0?' active':''}" onclick="switchTab('${uid}','${t.id}')">${t.label}</div>`).join('')}
      </div>
      ${contents.join('')}
    </div>`:''}
  </div>`;
}

function toggleCard(uid, firstTab){
  const body = document.getElementById(uid+'_body');
  const btn  = document.getElementById(uid+'_btn');
  if(!body) return;
  const isOpen = body.classList.toggle('open');
  if(btn) btn.textContent = isOpen ? '▴ ซ่อน' : '▾ ดูเพิ่ม';
  if(isOpen && firstTab) switchTab(uid, firstTab);
}

function switchTab(uid, tabId){
  document.querySelectorAll(`#${uid}_tabs .tab`).forEach(t=>{
    t.classList.toggle('active', t.textContent.trim() === tabIdToLabel(tabId));
  });
  // hide all, show target
  ['about','install','usage'].forEach(id=>{
    const el = document.getElementById(`${uid}_${id}`);
    if(el) el.classList.toggle('active', id===tabId);
  });
}

function tabIdToLabel(id){
  return {about:'ภาพรวม',install:'ติดตั้ง',usage:'วิธีใช้'}[id]||id;
}

function copyCode(btn){
  const pre = btn.nextElementSibling;
  navigator.clipboard.writeText(pre.textContent).then(()=>{
    btn.textContent='✓';
    setTimeout(()=>btn.textContent='copy',1200);
  });
}

// ── Build sidebar ──────────────────────────────────────────
function buildSidebar(){
  const nav = document.getElementById('sb-nav');
  nav.innerHTML = CATS.map(c=>{
    const cnt = c.id==='all' ? TOOLS.length : TOOLS.filter(t=>t.cat===c.id).length;
    return `<div class="sb-item${c.id==='all'?' active':''}" style="--c:${c.c}"
      onclick="showCat('${c.id}')">
      <span class="sb-dot" style="--c:${c.c}">${c.icon}</span>
      <span>${c.label}</span>
      <span class="sb-count">${cnt}</span>
    </div>`;
  }).join('');
}

// ── Build sections ─────────────────────────────────────────
function buildSections(){
  const wrap = document.getElementById('sections-wrap');
  wrap.innerHTML = CATS.filter(c=>c.id!=='all').map(c=>{
    const tools = TOOLS.filter(t=>t.cat===c.id);
    if(!tools.length) return '';
    return `<div class="sec" id="sec-${c.id}">
      <div class="sec-head">
        <div class="sec-icon" style="--c:${c.c}">${c.icon}</div>
        <div>
          <div class="sec-title">${c.label}</div>
        </div>
        <span class="sec-badge" style="--c:${c.c}">${tools.length} tools</span>
      </div>
      <div class="tool-grid">${tools.map(t=>renderCard(t)).join('')}</div>
    </div>`;
  }).join('');
}

// ── Navigation ─────────────────────────────────────────────
let currentCat='all';

function showCat(id){
  currentCat=id;
  document.getElementById('search-results').style.display='none';
  document.getElementById('empty').style.display='none';
  document.getElementById('sections-wrap').style.display='';
  document.querySelectorAll('.sb-item').forEach(b=>{
    b.classList.toggle('active', b.getAttribute('onclick')===`showCat('${id}')`);
  });
  const cat=CATS.find(c=>c.id===id);
  document.getElementById('pt').textContent = cat?cat.label:'ทั้งหมด';
  const cnt = id==='all'?TOOLS.length:TOOLS.filter(t=>t.cat===id).length;
  document.getElementById('pt-count').textContent = `${cnt} tools`;
  document.querySelectorAll('.sec').forEach(s=>{
    s.style.display = (id==='all'||s.id==='sec-'+id) ? '' : 'none';
  });
  document.getElementById('main').scrollTo({top:0,behavior:'smooth'});
}

// ── Search ─────────────────────────────────────────────────
document.getElementById('sb-search').addEventListener('input',function(){
  const q = this.value.trim().toLowerCase();
  const sw = document.getElementById('sections-wrap');
  const sr = document.getElementById('search-results');
  const em = document.getElementById('empty');
  if(!q){
    sr.style.display='none'; em.style.display='none'; sw.style.display='';
    showCat(currentCat); return;
  }
  sw.style.display='none';
  document.querySelectorAll('.sb-item').forEach(b=>b.classList.remove('active'));
  document.getElementById('pt').textContent=`ค้นหา "${this.value}"`;

  const hits = TOOLS.filter(t=>
    t.name.toLowerCase().includes(q)||
    t.desc.toLowerCase().includes(q)||
    (t.about&&t.about.toLowerCase().includes(q))||
    (t.usage&&t.usage.some(u=>u.body.toLowerCase().includes(q)))
  );

  if(!hits.length){
    sr.style.display='none'; em.style.display=''; return;
  }
  em.style.display='none'; sr.style.display='';
  document.getElementById('pt-count').textContent=`${hits.length} results`;
  const catLabels = Object.fromEntries(CATS.map(c=>[c.id,c]));
  sr.innerHTML=`<div class="tool-grid">${hits.map(t=>{
    const catInfo = catLabels[t.cat]||{icon:'',label:t.cat,c:'#5b8dee'};
    const card = renderCard(t, q);
    return card.replace(
      '<div class="card-desc">',
      `<span class="sr-cat-badge">${catInfo.icon} ${catInfo.label}</span>
       <div class="card-desc">`
    );
  }).join('')}</div>`;
});

// ── Keyboard shortcuts ──────────────────────────────────────
document.addEventListener('keydown',e=>{
  if((e.ctrlKey||e.metaKey)&&e.key==='k'){
    e.preventDefault();
    document.getElementById('sb-search').focus();
  }
  if(e.key==='Escape'){
    const sb=document.getElementById('sb-search');
    sb.value=''; sb.dispatchEvent(new Event('input')); sb.blur();
  }
});

// ── Back to top ────────────────────────────────────────────
document.getElementById('main').addEventListener('scroll',function(){
  document.getElementById('btt').classList.toggle('show',this.scrollTop>400);
});

// ── Init ────────────────────────────────────────────────────
buildSidebar();
buildSections();
showCat('all');
</script>
