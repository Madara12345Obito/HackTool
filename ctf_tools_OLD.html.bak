1|1|<!DOCTYPE html>
2|2|<html lang="th">
3|3|<head>
4|4|<meta charset="UTF-8">
5|5|<meta name="viewport" content="width=device-width, initial-scale=1.0">
6|6|<title>CTF Tools Reference</title>
7|7|<style>
8|8|  :root {
9|9|    --bg: #0d1117;
10|10|    --bg2: #161b22;
11|11|    --bg3: #21262d;
12|12|    --border: #30363d;
13|13|    --text: #c9d1d9;
14|14|    --muted: #8b949e;
15|15|    --accent: #58a6ff;
16|16|    --accent2: #3fb950;
17|17|    --accent3: #f78166;
18|18|    --accent4: #d2a8ff;
19|19|    --accent5: #ffa657;
20|20|    --accent6: #79c0ff;
21|21|    --tag-bg: #1f3a5f;
22|22|    --search-bg: #0d1117;
23|23|  }
24|24|  * { box-sizing: border-box; margin: 0; padding: 0; }
25|25|  body { background: var(--bg); color: var(--text); font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; font-size: 14px; line-height: 1.6; }
26|26|
27|27|  /* Layout */
28|28|  #app { display: flex; min-height: 100vh; }
29|29|  #sidebar { width: 260px; min-width: 260px; background: var(--bg2); border-right: 1px solid var(--border); position: sticky; top: 0; height: 100vh; overflow-y: auto; display: flex; flex-direction: column; }
30|30|  #main { flex: 1; padding: 32px 40px; max-width: 1100px; }
31|31|
32|32|  /* Sidebar */
33|33|  .sidebar-header { padding: 20px 16px 12px; border-bottom: 1px solid var(--border); }
34|34|  .sidebar-header h1 { font-size: 16px; font-weight: 700; color: var(--accent); letter-spacing: .3px; }
35|35|  .sidebar-header p { font-size: 11px; color: var(--muted); margin-top: 2px; }
36|36|  #search-box { margin: 12px; padding: 8px 12px; background: var(--search-bg); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 13px; width: calc(100% - 24px); outline: none; transition: border .2s; }
37|37|  #search-box:focus { border-color: var(--accent); }
38|38|  .nav-section { padding: 8px 0; }
39|39|  .nav-label { padding: 4px 16px; font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .8px; }
40|40|  .nav-item { display: flex; align-items: center; gap: 8px; padding: 6px 16px; cursor: pointer; border-radius: 0; transition: background .15s; font-size: 13px; color: var(--text); text-decoration: none; border: none; background: none; width: 100%; text-align: left; }
41|41|  .nav-item:hover, .nav-item.active { background: var(--bg3); color: var(--accent); }
42|42|  .nav-item .icon { font-size: 15px; width: 20px; text-align: center; }
43|43|  .nav-count { margin-left: auto; background: var(--bg3); color: var(--muted); font-size: 10px; padding: 1px 6px; border-radius: 10px; }
44|44|
45|45|  /* Main content */
46|46|  .page-header { margin-bottom: 32px; }
47|47|  .page-header h2 { font-size: 26px; font-weight: 700; margin-bottom: 6px; }
48|48|  .page-header p { color: var(--muted); font-size: 14px; }
49|49|
50|50|  .section { margin-bottom: 48px; scroll-margin-top: 24px; }
51|51|  .section-header { display: flex; align-items: center; gap: 10px; margin-bottom: 18px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
52|52|  .section-icon { font-size: 22px; }
53|53|  .section-title { font-size: 20px; font-weight: 700; }
54|54|  .section-desc { color: var(--muted); font-size: 13px; margin-top: 2px; }
55|55|
56|56|  .subsection { margin-bottom: 20px; }
57|57|  .subsection-title { font-size: 12px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .8px; margin-bottom: 10px; }
58|58|
59|59|  /* Tool cards */
60|60|  .tool-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 12px; }
61|61|  .tool-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; transition: border-color .2s, transform .15s; cursor: default; }
62|62|  .tool-card:hover { border-color: var(--accent); transform: translateY(-1px); }
63|63|  .tool-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-bottom: 6px; }
64|64|  .tool-name { font-weight: 600; font-size: 14px; color: var(--accent); }
65|65|  .tool-link { display: inline-flex; align-items: center; gap: 4px; color: var(--accent); font-size: 12px; text-decoration: none; background: var(--tag-bg); padding: 2px 8px; border-radius: 4px; white-space: nowrap; }
66|66|  .tool-link:hover { background: var(--accent); color: #000; }
67|67|  .tool-desc { font-size: 13px; color: var(--text); margin-bottom: 8px; }
68|68|  .tool-usage { background: var(--bg3); border-radius: 5px; padding: 8px 10px; margin-top: 8px; }
69|69|  .tool-usage-label { font-size: 10px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 4px; }
70|70|  .tool-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }
71|71|  .tag { font-size: 10px; padding: 2px 7px; border-radius: 12px; font-weight: 500; }
72|72|  .tag-online { background: #1a3a2a; color: var(--accent2); }
73|73|  .tag-cli { background: #3a1a1a; color: var(--accent3); }
74|74|  .tag-python { background: #2a1a3a; color: var(--accent4); }
75|75|  .tag-java { background: #3a2a1a; color: var(--accent5); }
76|76|  .tag-ruby { background: #1a2a3a; color: var(--accent6); }
77|77|
78|78|  /* Code blocks */
79|79|  pre { background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; padding: 12px 14px; overflow-x: auto; font-size: 12px; line-height: 1.7; font-family: 'SFMono-Regular',Consolas,'Liberation Mono',Menlo,monospace; color: #e6edf3; margin: 8px 0; }
80|80|  code { background: var(--bg3); padding: 1px 5px; border-radius: 3px; font-size: 12px; font-family: 'SFMono-Regular',Consolas,monospace; color: #e6edf3; }
81|81|
82|82|  /* Tips/notes */
83|83|  .tip { background: #132034; border-left: 3px solid var(--accent); border-radius: 0 6px 6px 0; padding: 10px 14px; margin: 12px 0; font-size: 13px; }
84|84|  .warn { background: #2a1f0e; border-left: 3px solid var(--accent5); border-radius: 0 6px 6px 0; padding: 10px 14px; margin: 12px 0; font-size: 13px; }
85|85|
86|86|  /* Search highlight */
87|87|  mark { background: #3d2c00; color: #ffd700; border-radius: 2px; padding: 0 2px; }
88|88|
89|89|  /* Search results */
90|90|  #search-results { display: none; }
91|91|  .search-result-item { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; margin-bottom: 8px; }
92|92|  .search-result-item:hover { border-color: var(--accent); }
93|93|  .search-result-cat { font-size: 11px; color: var(--muted); margin-bottom: 3px; }
94|94|
95|95|  /* Scrollbar */
96|96|  ::-webkit-scrollbar { width: 6px; }
97|97|  ::-webkit-scrollbar-track { background: var(--bg2); }
98|98|  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
99|99|
100|100|  /* Responsive */
101|101|  @media (max-width: 768px) {
102|102|    #sidebar { display: none; }
103|103|    #main { padding: 16px; }
104|104|    .tool-grid { grid-template-columns: 1fr; }
105|105|  }
106|106|
107|107|  /* Back to top */
108|108|  #back-top { position: fixed; bottom: 24px; right: 24px; background: var(--accent); color: #000; border: none; border-radius: 50%; width: 40px; height: 40px; font-size: 18px; cursor: pointer; opacity: 0; transition: opacity .3s; display: flex; align-items: center; justify-content: center; }
109|109|  #back-top.visible { opacity: 1; }
110|110|</style>
111|111|</head>
112|112|<body>
113|113|<div id="app">
114|114|<nav id="sidebar">
115|115|  <div class="sidebar-header">
116|116|    <h1>⚑ CTF Tools</h1>
117|117|    <p>Reference &amp; Cheatsheet</p>
118|118|  </div>
119|119|  <input id="search-box" type="text" placeholder="ค้นหาเครื่องมือ..." autocomplete="off">
120|120|  <div class="nav-section">
121|121|    <div class="nav-label">Categories</div>
122|122|    <button class="nav-item active" onclick="showSection('all')"><span class="icon">🏠</span>ทั้งหมด</button>
123|123|    <button class="nav-item" onclick="showSection('training')"><span class="icon">🚩</span>Training <span class="nav-count">4</span></button>
124|124|    <button class="nav-item" onclick="showSection('general')"><span class="icon">📋</span>General <span class="nav-count">9</span></button>
125|125|    <button class="nav-item" onclick="showSection('crypto')"><span class="icon">🔒</span>Cryptography <span class="nav-count">14</span></button>
126|126|    <button class="nav-item" onclick="showSection('stego')"><span class="icon">🎨</span>Steganography <span class="nav-count">8</span></button>
127|127|    <button class="nav-item" onclick="showSection('web')"><span class="icon">🕸️</span>Web <span class="nav-count">7</span></button>
128|128|    <button class="nav-item" onclick="showSection('pwn')"><span class="icon">🐛</span>Pwn / Binary <span class="nav-count">5</span></button>
129|129|    <button class="nav-item" onclick="showSection('forensics')"><span class="icon">🕵️</span>Forensics <span class="nav-count">6</span></button>
130|130|    <button class="nav-item" onclick="showSection('osint')"><span class="icon">🌐</span>OSINT <span class="nav-count">4</span></button>
131|131|    <button class="nav-item" onclick="showSection('reversing')"><span class="icon">↩️</span>Reversing <span class="nav-count">4</span></button>
132|132|    <button class="nav-item" onclick="showSection('network')"><span class="icon">📡</span>Network <span class="nav-count">5</span></button>
133|133|    <button class="nav-item" onclick="showSection('misc')"><span class="icon">🔧</span>Misc / Tips <span class="nav-count">8</span></button>
134|134|  </div>
135|135|  <div style="margin-top:auto;padding:12px 16px;border-top:1px solid var(--border);font-size:11px;color:var(--muted);">
136|136|    Based on <a href="https://github.com/gregalletti/CTF_tools" style="color:var(--accent);text-decoration:none;">gregalletti/CTF_tools</a><br>Extended by Kiro 🤖
137|137|  </div>
138|138|</nav>
139|139|<main id="main">
140|140|
141|
142|<!-- SEARCH RESULTS -->
143|<div id="search-results">
144|  <div class="page-header"><h2>🔍 ผลการค้นหา</h2><p id="search-count"></p></div>
145|  <div id="search-list"></div>
146|</div>
147|
148|<!-- ALL SECTIONS WRAPPER -->
149|<div id="all-sections">
150|
151|<!-- TRAINING -->
152|<div class="section" id="sec-training">
153|  <div class="section-header">
154|    <span class="section-icon">🚩</span>
155|    <div>
156|      <div class="section-title">Training</div>
157|      <div class="section-desc">เว็บฝึกทักษะ CTF สำหรับมือใหม่และมืออาชีพ</div>
158|    </div>
159|  </div>
160|  <div class="tool-grid">
161|    <div class="tool-card">
162|      <div class="tool-card-top"><span class="tool-name">picoCTF</span><a class="tool-link" href="https://picoctf.org/" target="_blank">🔗 เปิด</a></div>
163|      <div class="tool-desc">แพลตฟอร์ม CTF สำหรับนักเรียน/นักศึกษา จาก Carnegie Mellon University มี challenge ครบทุก category ระดับ beginner ถึง intermediate</div>
164|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
165|    </div>
166|    <div class="tool-card">
167|      <div class="tool-card-top"><span class="tool-name">OverTheWire</span><a class="tool-link" href="https://overthewire.org/wargames/" target="_blank">🔗 เปิด</a></div>
168|      <div class="tool-desc">Wargames แบบ SSH-based เหมาะสำหรับฝึก Linux, privilege escalation, binary exploitation เริ่มต้นที่ Bandit สำหรับ beginner</div>
169|      <div class="tool-usage">
170|        <div class="tool-usage-label">เริ่มต้น</div>
171|        <pre>ssh bandit0@bandit.labs.overthewire.org -p 2220
172|# password: bandit0</pre>
173|      </div>
174|      <div class="tool-tags"><span class="tag tag-cli">CLI</span><span class="tag tag-online">Online</span></div>
175|    </div>
176|    <div class="tool-card">
177|      <div class="tool-card-top"><span class="tool-name">pwnable.kr</span><a class="tool-link" href="http://pwnable.kr/" target="_blank">🔗 เปิด</a></div>
178|      <div class="tool-desc">เน้น binary exploitation / pwn challenges เป็นหลัก มี challenge ตั้งแต่ง่ายมากจนถึงยากมาก</div>
179|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
180|    </div>
181|    <div class="tool-card">
182|      <div class="tool-card-top"><span class="tool-name">capturetheflag.it</span><a class="tool-link" href="https://capturetheflag.it/risorse/come-imparo" target="_blank">🔗 เปิด</a></div>
183|      <div class="tool-desc">รวม resources สอน CTF ภาษาอิตาลี มีแหล่งเรียนรู้หลายอย่าง</div>
184|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
185|    </div>
186|  </div>
187|</div>
188|
189|<!-- GENERAL -->
190|<div class="section" id="sec-general">
191|  <div class="section-header">
192|    <span class="section-icon">📋</span>
193|    <div>
194|      <div class="section-title">General Tools</div>
195|      <div class="section-desc">เครื่องมือทั่วไปที่ใช้ได้ทุก category</div>
196|    </div>
197|  </div>
198|  <div class="tool-grid">
199|    <div class="tool-card">
200|      <div class="tool-card-top"><span class="tool-name">CyberChef</span><a class="tool-link" href="https://gchq.github.io/CyberChef/" target="_blank">🔗 เปิด</a></div>
201|      <div class="tool-desc">เครื่องมือ all-in-one จาก GCHQ ทำได้ทุกอย่าง: decode/encode base64, XOR, hash, compress, hex dump, regex, และอีกร้อยกว่า operation สามารถ chain operations ต่อกันได้</div>
202|      <div class="tool-usage">
203|        <div class="tool-usage-label">ตัวอย่าง Recipe</div>
204|        <pre>From Base64 → XOR (key: 0x41) → To Hex</pre>
205|      </div>
206|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
207|    </div>
208|    <div class="tool-card">
209|      <div class="tool-card-top"><span class="tool-name">Hex Editor Online</span><a class="tool-link" href="https://hexed.it/" target="_blank">🔗 เปิด</a></div>
210|      <div class="tool-desc">Hex editor ออนไลน์ drag &amp; drop ไฟล์เพื่อดู/แก้ hex bytes ได้ทันที มีฟีเจอร์ search, highlight, export</div>
211|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
212|    </div>
213|    <div class="tool-card">
214|      <div class="tool-card-top"><span class="tool-name">Katana (John Hammond)</span><a class="tool-link" href="https://github.com/JohnHammond/ctf-katana" target="_blank">🔗 GitHub</a></div>
215|      <div class="tool-desc">รวม CTF tools และ cheatsheet ขนาดใหญ่มากจาก John Hammond ครอบคลุมทุก category มีทั้ง scripts และ one-liners</div>
216|      <div class="tool-tags"><span class="tag tag-cli">CLI</span><span class="tag tag-python">Python</span></div>
217|    </div>
218|    <div class="tool-card">
219|      <div class="tool-card-top"><span class="tool-name">Online Converter</span><a class="tool-link" href="https://www.rapidtables.com/convert/number/ascii-hex-bin-dec-converter.html" target="_blank">🔗 เปิด</a></div>
220|      <div class="tool-desc">แปลง ASCII / Hex / Dec / Bin / Base64 ได้ทีละหลาย format พร้อมกัน</div>
221|      <div class="tool-usage">
222|        <div class="tool-usage-label">Command Line แทน (ใน terminal)</div>
223|        <pre>python3 -c "print(bytes.fromhex('666c6167').decode())"
224|echo -n 'flag' | xxd
225|echo -n 'flag' | base64</pre>
226|      </div>
227|      <div class="tool-tags"><span class="tag tag-online">Online</span><span class="tag tag-cli">CLI</span></div>
228|    </div>
229|    <div class="tool-card">
230|      <div class="tool-card-top"><span class="tool-name">XOR Calculator</span><a class="tool-link" href="http://xor.pw/" target="_blank">🔗 เปิด</a></div>
231|      <div class="tool-desc">คำนวณ XOR ออนไลน์ ทั้ง single byte, multi-byte key, และ bruteforce XOR key</div>
232|      <div class="tool-usage">
233|        <div class="tool-usage-label">Python XOR one-liner</div>
234|        <pre>python3 -c "ct=bytes.fromhex('1b3b1b'); key=0x41; print(bytes([b^key for b in ct]))"
235|# XOR with repeating key:
236|python3 -c "
237|from itertools import cycle
238|ct = bytes.fromhex('deadbeef')
239|key = b'key'
240|print(bytes([a^b for a,b in zip(ct,cycle(key))]))
241|"</pre>
242|      </div>
243|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
244|    </div>
245|    <div class="tool-card">
246|      <div class="tool-card-top"><span class="tool-name">ASCII Table</span><a class="tool-link" href="http://www.asciitable.com/" target="_blank">🔗 เปิด</a></div>
247|      <div class="tool-desc">ตาราง ASCII ครบทั้ง decimal, hex, octal และ HTML entity ควรเปิดค้างไว้ตลอด</div>
248|      <div class="tool-usage">
249|        <div class="tool-usage-label">Python quick lookup</div>
250|        <pre>python3 -c "print(ord('A'), chr(65))"  # 65, 'A'</pre>
251|      </div>
252|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
253|    </div>
254|    <div class="tool-card">
255|      <div class="tool-card-top"><span class="tool-name">Zip Password Cracker</span><a class="tool-link" href="https://passwordrecovery.io/zip-file-password-removal/" target="_blank">🔗 เปิด</a></div>
256|      <div class="tool-desc">ถอด password ไฟล์ ZIP ออนไลน์ฟรี สำหรับ password ที่ไม่ซับซ้อน</div>
257|      <div class="tool-usage">
258|        <div class="tool-usage-label">หรือใช้ john / hashcat</div>
259|        <pre>zip2john secret.zip > zip.hash
260|john zip.hash --wordlist=/usr/share/wordlists/rockyou.txt</pre>
261|      </div>
262|      <div class="tool-tags"><span class="tag tag-online">Online</span><span class="tag tag-cli">CLI</span></div>
263|    </div>
264|    <div class="tool-card">
265|      <div class="tool-card-top"><span class="tool-name">Github Secrets</span><a class="tool-link" href="https://github.com/neodyme-labs/github-secrets" target="_blank">🔗 GitHub</a></div>
266|      <div class="tool-desc">ค้นหา dangling commits และ force-pushed commits ใน GitHub repo ที่อาจซ่อนข้อมูลลับไว้</div>
267|      <div class="tool-tags"><span class="tag tag-cli">CLI</span></div>
268|    </div>
269|    <div class="tool-card">
270|      <div class="tool-card-top"><span class="tool-name">Regex Check</span><a class="tool-link" href="https://www.debuggex.com/" target="_blank">🔗 เปิด</a></div>
271|      <div class="tool-desc">ทดสอบ regular expression แบบ visual มี diagram แสดง state machine</div>
272|      <div class="tool-tags"><span class="tag tag-online">Online</span></div>
273|    </div>
274|  </div>
275|</div>
